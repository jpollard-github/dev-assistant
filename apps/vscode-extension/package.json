{
  "name": "dev-assistant-vscode-extension",
  "version": "0.1.0",
  "private": false,
  "displayName": "Dev Assistant",
  "description": "Local-first multi-agent development assistant for VS Code.",
  "publisher": "dev-assistant-local",
  "repository": {
    "type": "git",
    "url": "https://github.com/jpollard-github/dev-assistant.git"
  },
  "homepage": "https://github.com/jpollard-github/dev-assistant",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/apps/vscode-extension/src/index.js",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "ai",
    "agents",
    "development",
    "review"
  ],
  "files": [
    "dist",
    "resources",
    "README.md"
  ],
  "activationEvents": [
    "onView:devAssistant.tasks",
    "onCommand:devAssistant.startTask",
    "onCommand:devAssistant.reviewCurrentDiff",
    "onCommand:devAssistant.generateTestsForCurrentFile",
    "onCommand:devAssistant.explainTechnicalDebt",
    "onCommand:devAssistant.showHistory",
    "onCommand:devAssistant.cancelTask"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devAssistant",
          "title": "Dev Assistant",
          "icon": "resources/activity.svg"
        }
      ]
    },
    "views": {
      "devAssistant": [
        {
          "id": "devAssistant.tasks",
          "name": "Active Tasks"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "devAssistant.tasks",
        "contents": "### Dev Assistant\nKeep the sidebar narrow and launch work from here.\n\n[Start Assistant Task](command:devAssistant.startTask)\n[Review Current Diff](command:devAssistant.reviewCurrentDiff)\n[Generate Tests For Current File](command:devAssistant.generateTestsForCurrentFile)\n[Explain Technical Debt](command:devAssistant.explainTechnicalDebt)\n[Show Assistant History](command:devAssistant.showHistory)"
      }
    ],
    "commands": [
      {
        "command": "devAssistant.startTask",
        "title": "Dev Assistant: Start Assistant Task"
      },
      {
        "command": "devAssistant.reviewCurrentDiff",
        "title": "Dev Assistant: Review Current Diff"
      },
      {
        "command": "devAssistant.generateTestsForCurrentFile",
        "title": "Dev Assistant: Generate Tests For Current File"
      },
      {
        "command": "devAssistant.explainTechnicalDebt",
        "title": "Dev Assistant: Explain Technical Debt"
      },
      {
        "command": "devAssistant.showHistory",
        "title": "Dev Assistant: Show Assistant History"
      },
      {
        "command": "devAssistant.cancelTask",
        "title": "Dev Assistant: Cancel Active Task"
      },
      {
        "command": "devAssistant.openPendingDiff",
        "title": "Dev Assistant: Open Pending Diff"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "devAssistant.openPendingDiff",
          "when": "view == devAssistant.tasks && viewItem == devAssistant.task",
          "group": "inline"
        },
        {
          "command": "devAssistant.cancelTask",
          "when": "view == devAssistant.tasks && viewItem == devAssistant.task",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Dev Assistant",
      "properties": {
        "devAssistant.telemetry.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Reserved for future opt-in diagnostics. Source code telemetry stays disabled by default."
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "prepare:vsix": "node ./scripts/prepare-vsix.mjs",
    "package:vsix": "node ./scripts/prepare-vsix.mjs && npx --yes @vscode/vsce package --no-dependencies --out ../../dist/dev-assistant.vsix",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^24.0.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
