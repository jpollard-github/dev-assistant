{
  "name": "@dev-assistant/cli",
  "version": "0.1.0",
  "private": false,
  "description": "CLI for the local-first Dev Assistant multi-agent workflow.",
  "license": "UNLICENSED",
  "type": "module",
  "bin": {
    "dev-assistant": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "dev": "node dist/index.js",
    "package:tarball": "pnpm pack --pack-destination ../../dist",
    "test": "vitest run --passWithNoTests"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "development"
  ],
  "dependencies": {
    "@dev-assistant/agents": "workspace:*",
    "@dev-assistant/core": "workspace:*",
    "@dev-assistant/llm": "workspace:*",
    "@dev-assistant/mcp-servers": "workspace:*",
    "@dev-assistant/shared": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
